{
  "manifest_version": 3,
  "name": "PushGit",
  "version": "1.0.0",
  "description": "One-click scoped push tokens for GitHub — pick a repo, get a token, done.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://github.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PushGit — Create a push token",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["auth_watch.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://github.com/settings/personal-access-tokens/new*",
        "https://github.com/settings/personal-access-tokens*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*/*"],
      "js": ["detect.js"],
      "run_at": "document_idle"
    }
  ]
}
